{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2017", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@acte-de-presence/banner": ["libs/api/banner/src/index.ts"],
      "@acte-de-presence/lib-zip": ["libs/api/lib-zip/src/index.ts"],
      "@acte-de-presence/utils": ["libs/api/utils/src/index.ts"],
      "@acte-de-presence/vfs": ["libs/api/vfs/src/index.ts"],
      "@acte-de-presence/vfs-driver-local": [
        "libs/vfs/vfs-driver-local/src/index.ts"
      ],
      "@acte-de-presence/vfs-driver-memory": [
        "libs/vfs/driver-memory/src/index.ts"
      ],
      "@acte-de-presence/vfs-driver-zip": [
        "libs/vfs/vfs-driver-zip/src/index.ts"
      ]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
